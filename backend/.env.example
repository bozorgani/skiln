# Server
NODE_ENV=development
PORT=5000
ENABLE_RATE_LIMIT=false
TRUST_PROXY=false
JSON_BODY_LIMIT=1mb
FORM_BODY_LIMIT=1mb
MAX_IMAGE_UPLOAD_BYTES=10485760
MAX_VIDEO_UPLOAD_BYTES=524288000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/skiln
REDIS_URL=redis://127.0.0.1:6379

# URLs / CORS
FRONTEND_URL=http://localhost:3000
ADMIN_PANEL_URL=http://localhost:3001

# JWT / Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1d
JWT_COOKIE_MAX_AGE=86400000
REFRESH_EXPIRES_IN=7d

# OTP
OTP_LENGTH=4
OTP_TTL_MS=120000
OTP_RESEND_WINDOW_MS=30000
OTP_RATE_LIMIT_WINDOW_MS=900000
OTP_RATE_LIMIT_MAX=5
OTP_VERIFY_RATE_LIMIT_WINDOW_MS=900000
OTP_VERIFY_RATE_LIMIT_MAX=10

# Storage: local | s3
STORAGE_DRIVER=local
BACKEND_PUBLIC_URL=http://localhost:5000
STORAGE_PUBLIC_URL=
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=skiln-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_ACL=
S3_CACHE_CONTROL=public, max-age=31536000, immutable

# Payment providers - optional
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
ZARINPAL_AMOUNT_MULTIPLIER=10
PAYMENT_CALLBACK_BASE_URL=http://localhost:5000
PAYIR_API_KEY=
IDPAY_API_KEY=
